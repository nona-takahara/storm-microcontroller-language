module literal
  port out "result" : number
  inst ADD gate : a=1, b=2 -> out="result"
end

module absent
  port out "result" : number
  inst ADD gate : b=2 -> out="result"
end

module attribute_a
  port in "value" : number
  port out "result" : number
  inst CLAMP gate (min=0, max=1) : value="value" -> out="result"
end

module attribute_b
  port in "value" : number
  port out "result" : number
  inst CLAMP gate (min=-1, max=1) : value="value" -> out="result"
end
